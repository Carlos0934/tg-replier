# Version control
.git/
.gitignore

# Runtime data (must be volume-mounted, not baked in)
data/

# Environment files (secrets)
.env
.env.*
!.env.example

# Editor / agent / IDE metadata
.agents/
.atl/
.claude/
.kiro/
.windsurf/
.vscode/
.idea/

# OS leftovers
.DS_Store
Thumbs.db
NUL

